# Copy to cc.env and fill in real values. cc.env is gitignored.
# Then: chmod 600 cc.env

# Mail provider: "agentmail" (default) or "primitive".
# export CC_MAIL_PROVIDER=agentmail

# AgentMail inbox-scoped API key and the inbox to watch.
export AGENTMAIL_API_KEY=your-inbox-scoped-api-key-here
export AGENTMAIL_INBOX=you@agentmail.to

# Primitive backend only. Any local-part at your Primitive domain can receive
# mail, so PRIMITIVE_INBOX can be a readable role address such as
# taskcodex@your-domain.primitive.email.
# export CC_MAIL_PROVIDER=primitive
# export PRIMITIVE_AUTH_TOKEN=your-primitive-bearer-token
# export PRIMITIVE_INBOX=taskcodex@your-domain.primitive.email
# export PRIMITIVE_POLL_INTERVAL=15

# Which terminal to open a new Claude Code session in: "cmux" or "ghostty".
export CC_TERMINAL=cmux

# Comma-separated sender allowlist. Mail from anyone else, or that fails
# DKIM/SPF, is dropped. Keep this tight - it is the gate on who can drive
# your machine.
export CC_ALLOWED_FROM=you@example.com,your-agent@example.com

# cmux backend only: absolute path to the cmux CLI. Override if cmux is
# installed somewhere other than the default app bundle.
# export CMUX_BIN=/Applications/cmux.app/Contents/Resources/bin/cmux

# How long (seconds) to wait for Claude's TUI to finish booting in a fresh
# surface before giving up. Heavy MCP/plugin setups cold-start past the 120s
# default; raise this if you see "ready marker not seen" bounces. If the wait
# elapses the task is NOT sent (the message stays unread and bounces back).
# export CC_READY_TIMEOUT=120
# How often (seconds) to re-check the surface for readiness during that wait.
# export CC_READY_POLL=3

# cmux backend only: required if you ran `setup_cmux.py --mode password`.
# Must match automation.socketPassword in ~/.config/cmux/cmux.json. Not needed
# for --mode allowAll. See the cmux setup section in the README.
# export CMUX_SOCKET_PASSWORD=your-cmux-socket-password

# Optional: runtime directory for prompts, attachments, and the dispatch log.
# export CC_HOME=$HOME/.agentmail-cc
